FLASK_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# Redis (use deploy/docker-compose.yml → redis-stack on localhost:6379)
REDIS_URL=redis://127.0.0.1:6379/0

# Hashing embedding width for POC skill vectors (must stay consistent per index)
EMBEDDING_DIM=128

# Set to 1 to expose GET /api/eva/knowledge/chunks (inspect chunked knowledge in Redis / memory)
EVA_EXPOSE_KNOWLEDGE_API=0

# --- LLM (pick one path) ---
# Important: do not list LLM_BASE_URL / LLM_MODEL / LLM_PROVIDER twice — dotenv uses the LAST value, which silently overrides Ollama with OpenAI (or vice versa).
# LLM_PROVIDER=auto → Ollama native if LLM_BASE_URL looks like Ollama (:11434 / hostname ollama), else OpenAI-style /v1/chat/completions.
#
# Path A — Ollama (local, no API key): install https://ollama.com then:
#   ollama serve
#   ollama pull llama3.2
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=llama3.2
LLM_PROVIDER=ollama
#
# Path B — OpenAI cloud (set key; use openai_compatible):
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai_compatible
# OPENAI_API_KEY=sk-...
#
# Path C — Any OpenAI-compatible proxy (LiteLLM, Azure OpenAI base path, etc.): same as B; set OPENAI_API_KEY if the server expects Bearer auth.
